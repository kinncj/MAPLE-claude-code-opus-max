{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/kinncj/AI-Development-Squad-Template/main/template/.claude/schemas/project.config.schema.json",
  "title": "MAPLE Project Configuration",
  "description": "Project-level configuration for the MAPLE platform (project.config.yaml).",
  "type": "object",
  "required": ["project"],
  "additionalProperties": false,
  "properties": {
    "project": {
      "type": "object",
      "description": "Project identity and metadata.",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable project name.",
          "minLength": 1
        },
        "repo": {
          "type": "string",
          "description": "GitHub repository in owner/repo format.",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "milestone": {
          "type": "string",
          "description": "Default GitHub milestone applied to new stories. Leave empty if not using milestones.",
          "default": ""
        }
      }
    },
    "sdlc": {
      "type": "object",
      "description": "SDLC pipeline mode and behaviour.",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "description": "standard: full Spec-Kit + 8-phase pipeline. spike: skips Spec-Kit; used for time-boxed research tasks.",
          "enum": ["standard", "spike"],
          "default": "standard"
        },
        "require_adr_for": {
          "type": "array",
          "description": "Change categories that mandate an ADR before proceeding.",
          "items": {
            "type": "string",
            "enum": [
              "new_dependency",
              "cross_boundary_change",
              "data_model_change",
              "auth_change",
              "mcp_adoption",
              "visual_identity_change"
            ]
          },
          "default": [
            "new_dependency",
            "cross_boundary_change",
            "data_model_change",
            "auth_change",
            "mcp_adoption",
            "visual_identity_change"
          ],
          "uniqueItems": true
        }
      }
    },
    "qa": {
      "type": "object",
      "description": "QA and test automation settings.",
      "additionalProperties": false,
      "properties": {
        "bdd": {
          "type": "string",
          "description": "BDD framework used for Gherkin scenario automation. cucumber = @cucumber/cucumber (JS/TS) or Cucumber-JVM (Java/.NET). behave = Python. none = disabled.",
          "enum": ["cucumber", "behave", "none"],
          "default": "cucumber"
        },
        "step_defs_dir": {
          "type": "string",
          "description": "Directory for generated step definitions, relative to project root.",
          "default": "tests/step-definitions"
        },
        "features_dir": {
          "type": "string",
          "description": "Directory where extracted .feature files are written, relative to project root.",
          "default": "tests/features"
        }
      }
    },
    "design": {
      "type": "object",
      "description": "Design system and UX settings.",
      "additionalProperties": false,
      "properties": {
        "ui_library": {
          "type": "string",
          "description": "Component library used for mockup generation and component scaffolding.",
          "enum": ["mantine", "tailwind", "shadcn", "none"],
          "default": "none"
        },
        "tokens_file": {
          "type": "string",
          "description": "Path to the W3C DTCG design tokens file, relative to project root.",
          "default": "docs/design/identity/tokens.json"
        },
        "wireframe_format": {
          "type": "string",
          "description": "Default format for wireframes generated by the wireframe-architect agent.",
          "enum": ["ascii", "svg", "html"],
          "default": "ascii"
        }
      }
    },
    "github": {
      "type": "object",
      "description": "GitHub integration settings. Populated by `maple labels` and `maple project bootstrap`.",
      "additionalProperties": false,
      "properties": {
        "project_number": {
          "type": ["integer", "null"],
          "description": "GitHub Project v2 number (numeric ID, not node ID). Set by `maple project bootstrap`.",
          "default": null
        },
        "project_node_id": {
          "type": ["string", "null"],
          "description": "GitHub Project v2 GraphQL node ID. Set by `maple project bootstrap`.",
          "default": null
        }
      }
    },
    "dod": {
      "type": "object",
      "description": "Definition of Done settings.",
      "additionalProperties": false,
      "properties": {
        "default": {
          "type": "array",
          "description": "Default DoD checklist items applied to every story. UI-bearing stories (ui: true) automatically append the design-specific items.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [
            "Unit tests green",
            "Integration tests green",
            "Cucumber scenarios green",
            "ADRs linked where required",
            "Documentation updated",
            "CHANGELOG entry added"
          ],
          "minItems": 1
        },
        "ui_additions": {
          "type": "array",
          "description": "Extra DoD items automatically appended for stories with ui: true.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [
            "Wireframe approved",
            "Mockup approved",
            "A11y audit passed (WCAG 2.2 AA)"
          ]
        }
      }
    }
  }
}
